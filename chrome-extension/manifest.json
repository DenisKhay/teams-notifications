{
  "manifest_version": 3,
  "name": "Teams Notifications Bridge",
  "version": "1.0.0",
  "description": "Bridges Microsoft Teams PWA notifications to the system tray daemon",
  "permissions": ["nativeMessaging", "alarms"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://teams.microsoft.com/*", "https://teams.live.com/*"],
      "js": ["relay.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://teams.microsoft.com/*", "https://teams.live.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
